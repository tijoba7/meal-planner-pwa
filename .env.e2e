# Fake Supabase credentials for E2E testing.
# Makes isSupabaseAvailable() return true without a real Supabase instance.
# All Supabase API calls are intercepted by Playwright route mocks in e2e/fixtures.ts.
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=test-anon-key-for-e2e-testing
