# Supabase — Social features backend
# Get these from your Supabase project dashboard > Settings > API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Push notifications — optional, app works without it
# Generate a VAPID key pair once: npx web-push generate-vapid-keys
# Only the PUBLIC key goes here (browser-side). Keep the private key on your push server.
VITE_VAPID_PUBLIC_KEY=

# Sentry — Error tracking (optional, app works without it)
# Get DSN from sentry.io > Project > Settings > Client Keys
VITE_SENTRY_DSN=https://your-key@sentry.io/your-project-id
# Optional: shown in Sentry releases UI (e.g. git commit SHA)
VITE_APP_VERSION=

# Sentry source maps upload (build-time only, not exposed to browser)
# Get auth token from sentry.io > Settings > Auth Tokens
SENTRY_AUTH_TOKEN=
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=meal-planner-pwa
